APP_DEBUG = false
BEGIN_LOG = true

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = your_database
USERNAME = your_username
PASSWORD = your_password
HOSTPORT = 3306
CHARSET = utf8
DEBUG = false

[CACHE]
DRIVER = file

[REDIS]
HOSTNAME = 127.0.0.1
HOSTPORT = 6379
PASSWORD =
SELECT = 0

[LANG]
default_lang = zh-cn

[WXQY]
# 企业微信配置（可选）
CORP_ID =
SECRET =
AGENT_ID =

[CORS]
# 跨域白名单，逗号分隔
ALLOW_ORIGINS = http://localhost:8080,http://192.168.10.17:9999/

[AI]
# AI 网关配置（可选）
DEEPSEEK_API_KEY =
DEEPSEEK_BASE_URL = https://api.deepseek.com/v1
ALIYUN_ACCESS_KEY_ID =
ALIYUN_ACCESS_KEY_SECRET =
